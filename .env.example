# Public URL for sitemap/robots (GitHub Pages project site)
NEXT_PUBLIC_SITE_URL=https://muhunami.github.io/My-Portfolio

# GitHub Pages project site lives under /RepoName — see .env.production (used by `next build`).
# For local `npm run dev`, Next.js ignores .env.production; app is at http://localhost:3000

# Optional: password for /admin (local dev). Production: set GitHub secret ADMIN_PASSWORD (or NEXT_PUBLIC_ADMIN_PASSWORD).
# NEXT_PUBLIC_ADMIN_PASSWORD=
