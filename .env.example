# Public URL for sitemap/robots (GitHub Pages project site)
NEXT_PUBLIC_SITE_URL=https://muhunami.github.io/My-Portfolio

# Set when building for GitHub Pages (repo name = path segment). CI sets this automatically.
# NEXT_PUBLIC_BASE_PATH=/My-Portfolio

# Local dev: leave NEXT_PUBLIC_BASE_PATH unset (site runs at http://localhost:3000)
